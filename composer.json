{
    "name": "sub-store-php",
    "description": "Advanced Subscription Manager for QX, Loon, Surge, Stash and Shadowrocket - PHP Version",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "ext-sqlite3": "*",
        "ext-curl": "*",
        "ext-mbstring": "*",
        "ext-json": "*",
        "symfony/yaml": "^6.0",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "SubStore\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SubStore\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:3000 -t public",
        "test": "phpunit"
    }
}
